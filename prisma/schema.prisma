// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // AÑADE ESTA LÍNEA O MODIFÍCALA SI YA EXISTE 'previewFeatures'
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./test.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- RELACIÓN AÑADIDA ---
  // Esto le dice a Prisma que un Usuario puede tener una lista
  // de registros nutricionales.
  records   NutritionalRecord[]
}

// Esto es lo que necesitas
model NutritionalRecord {
  id          Int      @id @default(autoincrement())
  description String
  calories    Int
  date        DateTime @default(now()) // <-- ¡AÑADE ESTO!
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}